{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "DB Connect",
    "version": "0.0.3",
    "identifier": "com.rajeshwar.db-connect",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "DB Connect",
                "width": 1280,
                "height": 800,
                "maximized": true,
                "titleBarStyle": "Overlay",
                "hiddenTitle": true,
                "trafficLightPosition": {
                    "x": 18,
                    "y": 28
                }
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "updater": {
        "active": true,
        "endpoints": [
            "https://github.com/imrj05/db-connect/releases/latest/download/latest.json"
        ],
        "dialog": false,
        "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCNkY5MzMzNDdEQ0EyQ0IKUldUTG90eEhNNU52dTdFQjN0dDVRL0VlRXZXK0dncEZjVWJEQnZWMEFlcFF5bVlLNVhHUEEvcW8K"
    }
}
