#!/usr/bin/env bash

# Read current version from package.json
VERSION=$(grep '"version"' package.json | head -1 | sed 's/.*"version": *"\(.*\)".*/\1/')

if [ -z "$VERSION" ]; then
  exit 0
fi

# Read previous commit's version (skip on very first commit)
if git rev-parse HEAD~1 >/dev/null 2>&1; then
  PREV_VERSION=$(git show HEAD~1:package.json 2>/dev/null \
    | grep '"version"' | head -1 \
    | sed 's/.*"version": *"\(.*\)".*/\1/' || echo "")
else
  PREV_VERSION=""
fi

# Create and push tag if version changed
if [ "$VERSION" != "$PREV_VERSION" ]; then
  TAG="v$VERSION"
  if git rev-parse "$TAG" >/dev/null 2>&1; then
    echo "post-commit: tag $TAG already exists — pushing it now..."
    git push origin "$TAG"
  else
    echo "post-commit: version changed ($PREV_VERSION → $VERSION), creating tag $TAG..."
    git tag "$TAG"
    echo "post-commit: pushing tag $TAG to origin..."
    git push origin "$TAG"
    echo "post-commit: done — GitHub Actions release workflow triggered."
  fi
fi
